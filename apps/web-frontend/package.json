{
  "name": "stellarium-web",
  "version": "0.1.0",
  "private": true,
  "description": "Stellarium Web is an online planetarium that lets you discover the night sky. It's easy to use and beautiful.",
  "author": "Stellarium Labs <contact@stellarium-labs.com>",
  "scripts": {
    "generate:panel-geometry": "node scripts/generate-panel-geometry.js",
    "prebuild": "npm run generate:panel-geometry",
    "predev": "npm run generate:panel-geometry",
    "build": "NODE_OPTIONS=--openssl-legacy-provider vue-cli-service build",
    "lint": "vue-cli-service lint",
    "dev": "NODE_OPTIONS=--openssl-legacy-provider vue-cli-service serve",
    "dev:8081": "bash scripts/start-dev-8081.sh",
    "stop:8081": "bash scripts/stop-dev-8081.sh",
    "i18n": "vue-cli-service i18n:report",
    "e2e": "npx playwright test",
    "e2e:biz": "node scripts/e2e-business-cli.mjs",
    "e2e:test001:sequential": "bash scripts/run-test001-sequential.sh",
    "e2e:scenario": "E2E_SCENARIO=tests/e2e/scenarios/example.yaml npx playwright test",
    "e2e:qhyccd:sdk:capture": "npx playwright test tests/e2e/qhyccd-flow-runner.spec.ts --headed",
    "mcp:e2e": "node scripts/mcp-e2e-server.mjs",
    "mcp:auto-test-update": "node scripts/mcp-auto-test-update-server.mjs",
    "e2e:ai-control:session": "npx tsx scripts/ai-control-session.ts",
    "e2e:ai-control:deep-verify": "bash scripts/ai-control-deep-verify.sh"
  },
  "dependencies": {
    "@mdi/font": "^3.6.95",
    "clipboard": "^2.0.11",
    "core-js": "^3.4.4",
    "echarts": "^5.4.3",
    "fitsjs": "^0.6.6",
    "leaflet": "^1.7.1",
    "leaflet-control-geocoder": "^1.13.0",
    "moment": "^2.29.4",
    "roboto-fontface": "*",
    "v-click-outside": "^3.1.2",
    "vue": "^2.6.10",
    "vue-cookie": "^1.1.4",
    "vue-fullscreen": "^2.1.5",
    "vue-i18n": "^8.0.0",
    "vue-jsonp": "^0.1.8",
    "vue-router": "^3.0.3",
    "vue2-leaflet": "^2.6.0",
    "vuetify": "^2.0.0",
    "vuex": "^3.0.1"
  },
  "devDependencies": {
    "@kazupon/vue-i18n-loader": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@playwright/test": "1.34.0",
    "playwright": "1.34.0",
    "@types/node": "^25.2.0",
    "@vue/cli-plugin-babel": "~4.5.15",
    "@vue/cli-plugin-eslint": "~4.5.15",
    "@vue/cli-service": "~4.5.15",
    "@vue/eslint-config-standard": "^5.1.0",
    "babel-eslint": "^10.0.3",
    "eslint": "^6.7.2",
    "eslint-plugin-import": "^2.20.1",
    "eslint-plugin-node": "^11.0.0",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-standard": "^4.0.0",
    "eslint-plugin-vue": "^6.1.2",
    "eslint-plugin-vuetify": "^1.0.0-beta.3",
    "sass": "^1.26.10",
    "sass-loader": "^10.0.2",
    "vue-cli-plugin-i18n": "~2.3.1",
    "vue-cli-plugin-vuetify": "~2.4.3",
    "vue-template-compiler": "^2.6.10",
    "vuetify-loader": "^1.2.2",
    "tsx": "^4.19.0",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "plugin:vue/essential"
    ],
    "plugins": [
      "vuetify"
    ],
    "rules": {
      "vuetify/no-deprecated-classes": "error",
      "vue/no-parsing-error": [
        2,
        {
          "x-invalid-end-tag": false
        }
      ]
    },
    "parserOptions": {
      "parser": "babel-eslint"
    }
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ],
  "eslintIgnore": [
    "/build/",
    "/dist/",
    "/*.js",
    "src/assets/js/*.js"
  ],
  "workspaces": [
    "src/plugins/*"
  ]
}
